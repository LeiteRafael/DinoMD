{
    "name": "dinomd",
    "version": "0.1.0",
    "description": "A clean Markdown reader web app",
    "author": "",
    "license": "MIT",
    "scripts": {
        "dev": "vite --config vite.web.config.js",
        "build": "vite build --config vite.web.config.js",
        "preview": "vite preview --config vite.web.config.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:all": "vitest run --coverage && playwright test",
        "lint": "eslint src tests --ext .js,.jsx --rulesdir ./eslint-rules",
        "lint:fix": "eslint src tests --ext .js,.jsx --fix --max-warnings=0 --rulesdir ./eslint-rules",
        "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"tests/**/*.{js,jsx}\"",
        "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"tests/**/*.{js,jsx}\"",
        "prepare": "husky"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "html2canvas": "^1.4.1",
        "material-icons": "^1.13.14",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-markdown": "^9.0.3",
        "react-resizable-panels": "^2.1.9",
        "rehype-pretty-code": "^0.14.0",
        "rehype-slug": "^6.0.0",
        "remark-frontmatter": "^5.0.0",
        "remark-gfm": "^4.0.1",
        "shiki": "^1.24.4",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.2.0",
        "@testing-library/user-event": "^14.5.2",
        "@vitejs/plugin-react": "^4.3.4",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.4",
        "eslint-plugin-react-hooks": "^4.6.2",
        "husky": "^9.1.7",
        "identity-obj-proxy": "^3.0.0",
        "jsdom": "^24.1.3",
        "prettier": "^3.8.1",
        "vite": "^6.3.0",
        "vitest": "^3.2.4"
    }
}
