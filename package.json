{
    "name": "dinomd",
    "version": "0.1.0",
    "description": "A clean Markdown reader desktop app",
    "main": "./out/main/index.js",
    "author": "",
    "license": "MIT",
    "scripts": {
        "dev": "electron-vite dev -- --no-sandbox --disable-gpu",
        "dev:web": "vite --config vite.web.config.js",
        "build": "electron-vite build",
        "build:web": "vite build --config vite.web.config.js",
        "preview:web": "vite preview --config vite.web.config.js",
        "preview": "electron-vite preview",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src tests --ext .js,.jsx --rulesdir ./eslint-rules",
        "lint:fix": "eslint src tests --ext .js,.jsx --fix --max-warnings=0 --rulesdir ./eslint-rules",
        "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"tests/**/*.{js,jsx}\"",
        "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"tests/**/*.{js,jsx}\"",
        "prepare": "husky"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "electron-store": "^8.2.0",
        "material-icons": "^1.13.14",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-markdown": "^9.0.3",
        "react-resizable-panels": "^2.1.9",
        "rehype-pretty-code": "^0.14.0",
        "rehype-slug": "^6.0.0",
        "remark-frontmatter": "^5.0.0",
        "remark-gfm": "^4.0.1",
        "shiki": "^1.24.4",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@babel/core": "^7.26.0",
        "@babel/preset-env": "^7.26.0",
        "@babel/preset-react": "^7.26.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.2.0",
        "@testing-library/user-event": "^14.5.2",
        "@vitejs/plugin-react": "^4.3.4",
        "babel-jest": "^29.7.0",
        "electron": "^34.0.0",
        "electron-builder": "^25.1.8",
        "electron-vite": "^2.3.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.4",
        "eslint-plugin-react-hooks": "^4.6.2",
        "husky": "^9.1.7",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "jest-util": "^29.7.0",
        "prettier": "^3.8.1"
    }
}
